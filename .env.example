# Copy this file to .env and fill in the providers you want the curator to use.
# You do not need all four — only the ones listed in curator/src/config.ts's
# `providers.enabled` array need a working key. Never commit the real .env file.

# Vertex Gemini adapter (Vertex AI Express Mode API key)
GEMINI_VERTEX_API_KEY=

# DeepSeek adapter (OpenAI-compatible API, https://api.deepseek.com)
DEEPSEEK_API_KEY=

# OpenAI adapter
OPENAI_API_KEY=

# Gemini Developer API adapter (Google AI Studio key)
GEMINI_API_KEY=

# Anthropic Claude adapter (hosted). Used by `--provider anthropic`.
ANTHROPIC_API_KEY=
# Optional: override the Anthropic API base URL (e.g. a hosted gateway/proxy).
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama / OpenAI-compatible local server (used by `npm run curate:local`).
# Base URL of the local server's OpenAI-compatible endpoint. Default:
# http://localhost:11434/v1 (Ollama). Point this at any OpenAI-protocol server
# (llama.cpp, vLLM, LM Studio, …) to run Hermes, "OpenClaw", or another local
# model — set the model tag in curator/src/config.ts's providers.models.ollama.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Optional: only needed if your local server enforces an API key.
# OLLAMA_API_KEY=

# Optional runtime overrides (normally left unset; config.ts is the source
# of truth for these). Uncomment to override for a single local run.
# CURATOR_DRY_RUN=true
# CURATOR_FORCE=true
