# Copy this file to .env and fill in the providers you want the curator to use.
# You do not need all four — only the ones listed in curator/src/config.ts's
# `providers.enabled` array need a working key. Never commit the real .env file.

# Vertex Gemini adapter (Vertex AI Express Mode API key)
GEMINI_VERTEX_API_KEY=

# DeepSeek adapter (OpenAI-compatible API, https://api.deepseek.com)
DEEPSEEK_API_KEY=

# OpenAI adapter
OPENAI_API_KEY=

# Gemini Developer API adapter (Google AI Studio key)
GEMINI_API_KEY=

# Optional runtime overrides (normally left unset; config.ts is the source
# of truth for these). Uncomment to override for a single local run.
# CURATOR_DRY_RUN=true
# CURATOR_FORCE=true
